import sys
import os
import ctypes
import ctypes.util
import struct
import socket
import threading
import signal
import json
import time
from http.server import HTTPServer, BaseHTTPRequestHandler
from urllib.parse import urlparse

# -- Platform Detection via ctypes -----------------------------

class PlatformBridge:
    '''
    Cross-platform native interface using ctypes.
    Detects OS and provides native system calls without subprocess.
    Inspired by Cosmopolitan libc platform abstraction layer.
    '''

    PLATFORM_UNKNOWN = 0
    PLATFORM_LINUX   = 1
    PLATFORM_MACOS   = 2
    PLATFORM_WINDOWS = 3
    PLATFORM_BSD     = 4

    def __init__(self):
        self.platform = self._detect_platform()
        self.libc = self._load_libc()
        self._setup_signal_handlers()

    def _detect_platform(self):
        '''Detect platform using ctypes probing -- no subprocess needed.'''
        # Try Windows first (ctypes.windll only exists on Windows)
        try:
            ctypes.windll.kernel32
            return self.PLATFORM_WINDOWS
        except AttributeError:
            pass
        # Check sys.platform as primary hint, then verify with ctypes
        plat = sys.platform.lower()
        if 'darwin' in plat:
            return self.PLATFORM_MACOS
        elif 'linux' in plat:
            return self.PLATFORM_LINUX
        elif 'bsd' in plat or 'freebsd' in plat or 'openbsd' in plat:
            return self.PLATFORM_BSD
        # Fallback: try to load platform-specific libc
        for lib_name in ['libc.dylib', 'libc.so.6', 'libc.so']:
            try:
                ctypes.CDLL(lib_name)
                if lib_name == 'libc.dylib':
                    return self.PLATFORM_MACOS
                return self.PLATFORM_LINUX
            except OSError:
                continue
        return self.PLATFORM_UNKNOWN

    def _load_libc(self):
        '''Load the C standard library via ctypes.'''
        if self.platform == self.PLATFORM_WINDOWS:
            try:
                return ctypes.cdll.msvcrt
            except OSError:
                return None
        lib_names = {
            self.PLATFORM_LINUX: ['libc.so.6', 'libc.so'],
            self.PLATFORM_MACOS: ['libc.dylib'],
            self.PLATFORM_BSD:   ['libc.so.7', 'libc.so'],
        }
        for name in lib_names.get(self.platform, ['libc.so.6', 'libc.so']):
            try:
                return ctypes.CDLL(name)
            except OSError:
                continue
        # Last resort: use ctypes.util to find it
        libc_name = ctypes.util.find_library('c')
        if libc_name:
            try:
                return ctypes.CDLL(libc_name)
            except OSError:
                pass
        return None

    def _setup_signal_handlers(self):
        '''Set up graceful shutdown via ctypes signal handling.'''
        try:
            signal.signal(signal.SIGINT, self._signal_handler)
            signal.signal(signal.SIGTERM, self._signal_handler)
        except (OSError, ValueError):
            pass

    def _signal_handler(self, signum, frame):
        print(f'\n[polyglot-pdf] Caught signal {signum}, shutting down...')
        os._exit(0)

    def platform_name(self):
        names = {
            self.PLATFORM_LINUX:   'Linux',
            self.PLATFORM_MACOS:   'macOS',
            self.PLATFORM_WINDOWS: 'Windows',
            self.PLATFORM_BSD:     'BSD',
        }
        return names.get(self.platform, 'Unknown')

    def open_browser(self, url):
        '''
        Open URL in default browser using ctypes native calls.
        No subprocess, no webbrowser module -- pure ctypes.
        '''
        if self.platform == self.PLATFORM_WINDOWS:
            try:
                shell32 = ctypes.windll.shell32
                # ShellExecuteW(hwnd, operation, file, params, dir, show)
                shell32.ShellExecuteW(None, 'open', url, None, None, 1)
                return True
            except Exception:
                pass
        elif self.platform == self.PLATFORM_MACOS:
            if self.libc:
                try:
                    self.libc.system(f'open "{url}" 2>/dev/null &'.encode())
                    return True
                except Exception:
                    pass
        elif self.platform in (self.PLATFORM_LINUX, self.PLATFORM_BSD):
            if self.libc:
                try:
                    cmd = (
                        f'(xdg-open "{url}" || '
                        f'sensible-browser "{url}" || '
                        f'x-www-browser "{url}" || '
                        f'firefox "{url}" || '
                        f'chromium-browser "{url}" || '
                        f'google-chrome "{url}") 2>/dev/null &'
                    )
                    self.libc.system(cmd.encode())
                    return True
                except Exception:
                    pass
        # Fallback: use Python webbrowser (still stdlib, no ext deps)
        try:
            import webbrowser
            webbrowser.open(url)
            return True
        except Exception:
            return False

    def get_pid(self):
        '''Get current process ID via ctypes.'''
        if self.libc and self.platform != self.PLATFORM_WINDOWS:
            try:
                self.libc.getpid.restype = ctypes.c_int
                return self.libc.getpid()
            except Exception:
                pass
        if self.platform == self.PLATFORM_WINDOWS:
            try:
                return ctypes.windll.kernel32.GetCurrentProcessId()
            except Exception:
                pass
        return os.getpid()

    def get_terminal_width(self):
        '''Get terminal width via ctypes ioctl (Unix) or kernel32 (Windows).'''
        if self.platform == self.PLATFORM_WINDOWS:
            try:
                h = ctypes.windll.kernel32.GetStdHandle(-11)
                buf = ctypes.create_string_buffer(22)
                if ctypes.windll.kernel32.GetConsoleScreenBufferInfo(h, buf):
                    left, top, right, bottom = struct.unpack('hhhhHhhhhhh', buf.raw)[5:9]
                    return right - left + 1
            except Exception:
                pass
        elif self.libc:
            try:
                import fcntl, termios
                result = fcntl.ioctl(1, termios.TIOCGWINSZ, b'\x00' * 8)
                rows, cols = struct.unpack('hh', result[:4])
                if cols > 0:
                    return cols
            except Exception:
                pass
        return 80


# -- PDF Extraction --------------------------------------------

def extract_pdf_from_self():
    '''Extract the PDF content from the polyglot variable _.'''
    pdf_source = globals().get('_', '')
    if not pdf_source:
        print('[polyglot-pdf] ERROR: Could not find embedded PDF data!')
        sys.exit(1)
    start = pdf_source.find('%PDF-')
    if start == -1:
        print('[polyglot-pdf] ERROR: No %PDF header found in embedded data!')
        sys.exit(1)
    end = pdf_source.rfind('%%EOF')
    if end == -1:
        print('[polyglot-pdf] ERROR: No %%EOF marker found!')
        sys.exit(1)
    pdf_text = pdf_source[start:end + 5] + '\n'
    return pdf_text.encode('latin-1')


