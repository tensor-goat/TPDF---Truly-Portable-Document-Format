# -- HTTP Request Handler --------------------------------------

class Holder:
    '''Holds the shared state for the server.'''
    pdf_bytes = b''
    platform_bridge = None

def make_handler():
    class PolyglotHandler(BaseHTTPRequestHandler):
        '''Zero-dependency HTTP handler that serves the embedded PDF.'''

        def do_GET(self):
            path = urlparse(self.path).path
            if path == '/' or path == '/index.html':
                html = VIEWER_HTML.encode('utf-8')
                self.send_response(200)
                self.send_header('Content-Type', 'text/html; charset=utf-8')
                self.send_header('Content-Length', str(len(html)))
                self.end_headers()
                self.wfile.write(html)
            elif path == '/doc.pdf':
                self.send_response(200)
                self.send_header('Content-Type', 'application/pdf')
                self.send_header('Content-Length', str(len(Holder.pdf_bytes)))
                self.send_header('Content-Disposition', 'inline; filename="polyglot.pdf"')
                self.send_header('Cache-Control', 'no-cache')
                self.end_headers()
                self.wfile.write(Holder.pdf_bytes)
            elif path == '/health':
                info = json.dumps({
                    'status': 'ok',
                    'type': 'polyglot-pdf',
                    'platform': Holder.platform_bridge.platform_name() if Holder.platform_bridge else 'unknown',
                    'pid': Holder.platform_bridge.get_pid() if Holder.platform_bridge else -1,
                    'pdf_size': len(Holder.pdf_bytes),
                    'technique': 'Albertini-polyglot + Tunney-portable',
                })
                self.send_response(200)
                self.send_header('Content-Type', 'application/json')
                self.end_headers()
                self.wfile.write(info.encode())
            elif path == '/shutdown':
                self.send_response(200)
                self.send_header('Content-Type', 'text/plain')
                self.end_headers()
                self.wfile.write(b'Shutting down...')
                threading.Thread(target=lambda: (time.sleep(0.5), os._exit(0))).start()
            else:
                self.send_response(404)
                self.end_headers()

        def log_message(self, format, *args):
            sys.stderr.write(f'  [{self.log_date_time_string()}] {args[0]}\n')

    return PolyglotHandler


# -- Main Entry Point ------------------------------------------

def serve_pdf():
    '''Main entry: extract PDF from self, start server, open browser.'''
    bridge = PlatformBridge()
    Holder.platform_bridge = bridge
    term_w = bridge.get_terminal_width()
    sep = '\u2500' * min(term_w - 2, 60)
    print(f'\n  {sep}')
    print(f'   POLYGLOT PDF \u2014 Self-Serving Document')
    print(f'   Platform:  {bridge.platform_name()} (detected via ctypes)')
    print(f'   PID:       {bridge.get_pid()} (retrieved via ctypes)')
    print(f'  {sep}\n')
    # Extract PDF bytes from the polyglot variable
    Holder.pdf_bytes = extract_pdf_from_self()
    print(f'  [*] Extracted PDF: {len(Holder.pdf_bytes)} bytes')
    # Find an available port
    port = 8432
    for attempt_port in range(8432, 8500):
        try:
            test_sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            test_sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            test_sock.bind(('127.0.0.1', attempt_port))
            test_sock.close()
            port = attempt_port
            break
        except OSError:
            continue
    url = f'http://127.0.0.1:{port}'
    print(f'  [*] Starting server on {url}')
    handler = make_handler()
    server = HTTPServer(('127.0.0.1', port), handler)
    # Open browser via ctypes after a short delay
    def delayed_open():
        time.sleep(0.4)
        print(f'  [*] Opening browser via ctypes ({bridge.platform_name()})...')
        if bridge.open_browser(url):
            print(f'  [*] Browser launched successfully')
        else:
            print(f'  [!] Could not auto-open browser. Visit: {url}')
    threading.Thread(target=delayed_open, daemon=True).start()
    print(f'  [*] Serving... Press Ctrl+C to stop.\n')
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print('\n  [*] Shutting down gracefully...')
        server.shutdown()


# -- Auto-launch when executed ---------------------------------
serve_pdf()
